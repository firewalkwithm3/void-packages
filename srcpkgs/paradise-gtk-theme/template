# Template file for 'paradise-gtk-theme'
pkgname=paradise-gtk-theme
version=20210322
revision=1
hostmakedepends="sassc meson inkscape optipng nodejs bc"
depends="gtk+3 gnome-themes-extra"
short_desc="Material Design theme for GNOME/GTK based desktop environments using the paradise colourscheme"
maintainer="fern <mail@fern.garden>"
license="GPL-2.0-only"
homepage="https://github.com/paradise-theme"
distfiles="https://github.com/nana-4/materia-theme/archive/refs/tags/v${version}.tar.gz"
checksum="4460af612cd70242543ac71023f8963eea39be059486e9ebe58b3846be74bcb5"

do_build() {
	./change_color.sh -t ${wrksrc}/build -o paradise <(echo -e "BG=151515\nFG=e8e3e3\nMATERIA_VIEW=151515\nMATERIA_SURFACE=1f1f1f\nHDR_BG=151515\nHDR_FG=e8e3e3\nSEL_BG=8c977d\n")
}

do_install() {
	vmkdir usr/share/themes
	vcopy ${wrksrc}/build/paradise usr/share/themes
}
