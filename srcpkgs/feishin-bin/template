# Template file for 'feishin-bin'
pkgname=feishin-bin
version=0.7.3
revision=1
short_desc="A modern self-hosted music player"
maintainer="fern <mail@fern.garden>"
license="GPL-3.0-only"
homepage=https://github.com/jeffvli/feishin
distfiles="https://github.com/jeffvli/feishin/releases/download/v${version}/Feishin-${version}-linux-x64.tar.xz"
checksum="323b52f68e126b4681fd651b8a6a220d1cd6cde621df3c56f5cf32b3b5231b58"

do_install() {
	vmkdir usr/lib/feishin
	vcopy * usr/lib/feishin

	vmkdir usr/bin
	ln -s /usr/lib/feishin/feishin ${DESTDIR}/usr/bin/

	vmkdir usr/share/applications
	vinstall ${FILESDIR}/feishin.desktop 644 usr/share/applications

	vmkdir usr/share/icons/hicolor
	for size in 32 64 128 256 512 1024; do
		vinstall resources/assets/icons/${size}x${size}.png 644 usr/share/icons/hicolor/${size}x${size}/apps/ feishin.png
	done
}

